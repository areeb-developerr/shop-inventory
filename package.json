{
  "name": "shop-ledger",
  "version": "2.0.0",
  "type": "commonjs",
  "description": "Pesticide shop ledger — inventory, sales, udhar, and accounts",
  "main": "main.js",
  "author": "You",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:frontend": "vite build",
    "build": "npm run build:frontend",
    "dist": "npm run build && electron-builder",
    "postinstall": "node -e \"try{require('child_process').execSync('npx electron-builder install-app-deps',{stdio:'inherit'})}catch(e){}\""
  },
  "build": {
    "appId": "com.shopledger.app",
    "productName": "Shop Ledger",
    "directories": {
      "output": "dist-electron",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "preload.js",
      "main.js",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!src/**/*",
      "!dashboard/**/*",
      "!supabase/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.6.1",
    "lucide-react": "^0.363.0",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
