{
  "name": "shop-inventory",
  "version": "1.0.1",
  "type": "commonjs",
  "description": "Shop inventory desktop app",
  "main": "main.js",
  "author": "You",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:frontend": "vite build",
    "build": "npm run build:frontend",
    "dist": "npm run build && electron-builder",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.yourshop.inventory",
    "productName": "Shop Inventory",
    "directories": {
      "output": "dist-electron",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "backend/**/*",
      "preload.js",
      "main.js",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!src/**/*",
      "!assets/**/*",
      "!*.md",
      "!.env.example"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/**/*",
      "backend/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dexie": "^4.0.8",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "framer-motion": "^12.23.13",
    "helmet": "^8.1.0",
    "lucide-react": "^0.363.0",
    "mongoose": "^8.17.1",
    "morgan": "^1.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.10",
    "rollup-plugin-visualizer": "^6.0.3"
  }
}
